{
  "mcpServers": {
    "legal-it": {
      "command": "bash",
      "args": [
        "-c",
        "cd \"${CLAUDE_PLUGIN_ROOT}/server\" && pip install -q -e . 2>/dev/null; python run_server.py"
      ],
      "env": {
        "MCP_CACHE_DIR": "${HOME}/.cache/mcp-legal-it",
        "LEGAL_PROFILE": "full"
      }
    }
  }
}
